apiVersion: v1
kind: Namespace
metadata:
  name: gitlab
---
apiVersion: v1
kind: Service
metadata:
  name: gitlab
  namespace: gitlab
spec:
  clusterIP: None
  selector:
    app: gitlab
  ports:
    - name: http
      port: 80
      targetPort: 80
    - name: ssh
      port: 22
      targetPort: 22
---
apiVersion: v1
kind: Service
metadata:
  name: gitlab-web
  namespace: gitlab
spec:
  type: NodePort
  selector:
    app: gitlab
  ports:
    - name: http
      port: 80
      targetPort: 80
      nodePort: __GITLAB_NODEPORT_HTTP__
---
apiVersion: v1
kind: Service
metadata:
  name: gitlab-ssh
  namespace: gitlab
spec:
  type: NodePort
  selector:
    app: gitlab
  ports:
    - name: ssh
      port: 22
      targetPort: 22
      nodePort: __GITLAB_NODEPORT_SSH__
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: gitlab
  namespace: gitlab
spec:
  serviceName: gitlab
  replicas: 1
  selector:
    matchLabels:
      app: gitlab
  template:
    metadata:
      labels:
        app: gitlab
    spec:
      terminationGracePeriodSeconds: 30
      containers:
        - name: gitlab
          image: __GITLAB_IMAGE__
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: 80
            - name: ssh
              containerPort: 22
          env:
            - name: GITLAB_ROOT_PASSWORD
              value: "__GITLAB_ROOT_PASSWORD__"
            - name: GITLAB_OMNIBUS_CONFIG
              value: |
                external_url '__GITLAB_EXTERNAL_URL__'
                nginx['listen_port'] = 80
                nginx['listen_https'] = false
                letsencrypt['enable'] = false
                gitlab_rails['gitlab_shell_ssh_port'] = __GITLAB_NODEPORT_SSH__
          volumeMounts:
            - name: config
              mountPath: /etc/gitlab
            - name: logs
              mountPath: /var/log/gitlab
            - name: data
              mountPath: /var/opt/gitlab
      volumes:
        - name: config
          emptyDir: {}
        - name: logs
          emptyDir: {}
        - name: data
          emptyDir: {}
